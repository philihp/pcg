{
  "name": "pcg",
  "version": "3.0.0",
  "description": "A functional typescript implementation of the PCG family random number generators",
  "keywords": [
    "prng",
    "rng",
    "random",
    "seeded",
    "seedable",
    "deterministic",
    "reproducible",
    "pcg",
    "sfc32",
    "mulberry32"
  ],
  "homepage": "https://github.com/philihp/pcg#readme",
  "bugs": "https://github.com/philihp/pcg/issues",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "/dist/"
  ],
  "repository": "https://github.com/philihp/pcg",
  "contributors": [
    "Kristóf Poduszló <kripod@protonmail.com>",
    "Philihp Busby <philihp@gmail.com>"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "prepare": "npm run build",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "test:coverage": "mkdir -p coverage && node --import tsx --test --experimental-test-coverage --test-coverage-exclude='src/__tests__/**' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info src/__tests__/*.test.ts",
    "test:watch": "node --import tsx --test --watch src/__tests__/*.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@philihp/prettier-config": "1.0.0",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "^24.0.0",
    "eslint": "10.4.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "prettier": "3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4"
  },
  "prettier": "@philihp/prettier-config"
}
